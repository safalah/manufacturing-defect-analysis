      <column caption='Ambient Temp C' datatype='real' name='[Ambient_Temp_C]' role='measure' type='quantitative' />
      <column caption='Anode Overhang mm' datatype='real' name='[Anode_Overhang_mm]' role='measure' type='quantitative' />
      <column caption='Batch ID' datatype='string' name='[Batch_ID]' role='dimension' type='nominal' />
      <column caption='Calculation1' datatype='real' name='[Calculation_0558616160202752]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_AVG(AVG([Anode_Overhang_mm]), -99, 0)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Scrap Rate' datatype='real' name='[Calculation_0558616165842949]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [QC_Grade] = &quot;Scrap&quot; THEN 1 ELSE 0 END) / COUNT([Cell_ID])' />
      </column>
      <column caption='Grade Rate' datatype='real' name='[Calculation_0558616166719494]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Cell_ID]) / TOTAL(COUNT([Cell_ID]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
